# Azure credentials and execution
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=siteline-azure-cdn-rg
AZURE_LOCATION=eastus
AUTO_APPROVE=false

# App and Siteline runtime settings
APP_NAME=siteline-azure-cdn-processor
SITELINE_WEBSITE_KEY=siteline_secret_replace_with_real_key
SITELINE_ENDPOINT=https://api.siteline.ai/v1/intake/pageview
SITELINE_DEBUG=false

# Storage for CDN logs
STORAGE_ACCOUNT_NAME=sitelineazurecdnlogs
LOG_CONTAINER_NAME=cdn-logs
AZURE_STORAGE_CONNECTION_STRING=

# Function processor
FUNCTION_APP_NAME=siteline-azure-cdn-processor
FUNCTION_NAME=blob-log-processor
FUNCTION_RUNTIME=node
FUNCTION_RUNTIME_VERSION=20
FUNCTIONS_EXTENSION_VERSION=4
FUNCTION_TIMEOUT_SECONDS=60
FUNCTION_MEMORY_MB=256
FUNCTION_ZIP_PATH=dist/function-app.zip

# Event Grid subscription
EVENT_SUBSCRIPTION_NAME=siteline-blob-log-created

# CDN diagnostic settings (set either CDN_ENDPOINT_RESOURCE_ID directly,
# or provide CDN_RESOURCE_GROUP + CDN_PROFILE_NAME + CDN_ENDPOINT_NAME)
CDN_ENDPOINT_RESOURCE_ID=
CDN_RESOURCE_GROUP=
CDN_PROFILE_NAME=
CDN_ENDPOINT_NAME=
CDN_DIAGNOSTIC_SETTINGS_NAME=siteline-cdn-logs
