{
  "name": "siteline-azure-cdn",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Azure Function processor for Azure CDN Blob access logs using @siteline/core",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup --config config/tsup.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --config config/eslint.config.mjs . --max-warnings=0",
    "format": "prettier --config config/prettier.config.cjs --write .",
    "test": "vitest run",
    "package": "npm run build && bash scripts/package.sh",
    "deploy": "bash scripts/deploy.sh",
    "setup:storage": "bash scripts/setup-storage.sh",
    "setup:function": "bash scripts/setup-function.sh",
    "setup:eventgrid": "bash scripts/setup-eventgrid.sh",
    "setup:cdn-logging": "bash scripts/setup-cdn-logging.sh",
    "setup:all": "bash scripts/setup-all.sh",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@azure/functions": "^4.7.2",
    "@azure/identity": "^4.13.0",
    "@azure/storage-blob": "^12.29.1",
    "@siteline/core": "^1.0.8",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
